# ============================================
# BHARAT RAILWAY - Environment Variables (DUMMY VALUES)
# ============================================
# Copy this file to bharat-railway-secrets/.env and replace with real values.

# Network
HOST_IP=xxx.xxx.xxx.xxx
DOCKER_NETWORK=project-network-placeholder

# PostgreSQL
POSTGRES_USER=db_user_placeholder
POSTGRES_PASSWORD=db_password_placeholder
POSTGRES_DB=db_name_placeholder
POSTGRES_HOST_PORT=xxxxx

# PgBouncer
PGBOUNCER_HOST_PORT=xxxxx

# Valkey
VALKEY_PASSWORD=valkey_password_placeholder
VALKEY_HOST_PORT=xxxxx

# Kafka
KAFKA_NODE_ID=x
KAFKA_HOST_PORT=xxxxx
KAFKA_EXTERNAL_HOST_PORT=xxxxx

# MinIO
MINIO_ROOT_USER=minio_admin_placeholder
MINIO_ROOT_PASSWORD=minio_password_placeholder
MINIO_API_HOST_PORT=xxxxx
MINIO_CONSOLE_HOST_PORT=xxxxx

# Grafana
GRAFANA_HOST_PORT=xxxxx

# Nginx
NGINX_HTTP_HOST_PORT=xxxx
NGINX_HTTPS_HOST_PORT=xxxx